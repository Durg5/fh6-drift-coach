# Drift Coach — environment template. Copy to .env and fill in.
# Most users won't need this file at all — the Settings UI in the app writes
# all AI provider keys to ~/.config/drift-coach/settings.json (outside the
# project tree). .env is only useful for one-shot defaults or CI.

# Forza Data Out — UDP listener
FORZA_PORT=5330
FORZA_BIND=0.0.0.0

# Nuxt dev/prod server port
PORT=3002

# AI providers — fill at least one (or set in the Settings UI in-app)
AI_PROVIDER=ollama-cloud

OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=minimax-m3:cloud

LOCAL_OLLAMA_URL=http://localhost:11434/v1
LOCAL_OLLAMA_MODEL=llama3

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
