{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drift Coach",
  "version": "0.1.0",
  "identifier": "io.driftcoach.app",
  "build": {
    "beforeBuildCommand": "npm run desktop:prebuild",
    "frontendDist": "../src-tauri/empty-frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Drift Coach contributors",
    "copyright": "MIT License",
    "homepage": "https://github.com/Durg5/drift-coach",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Forza drift telemetry + AI tuning coach",
    "longDescription": "Self-hosted Forza Horizon 6/5 telemetry dashboard with a drift-tuning AI coach. Records sessions, builds a per-car dyno from your runs, and chats with a local or hosted LLM that knows drift tuning specifically.",
    "resources": ["nuxt/**/*"],
    "externalBin": ["binaries/node-sidecar"],
    "windows": {
      "wix": {
        "language": ["en-US"],
        "bannerPath": "icons/installer-banner.png",
        "dialogImagePath": "icons/installer-dialog.png"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.png",
        "sidebarImage": "icons/nsis-sidebar.png",
        "installMode": "perUser",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 540,
          "height": 380
        },
        "appPosition": {
          "x": 110,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 430,
          "y": 180
        }
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libsoup-3.0-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
