{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drift Coach",
  "version": "0.1.0",
  "identifier": "io.driftcoach.app",
  "build": {
    "beforeBuildCommand": "npm run desktop:prebuild",
    "frontendDist": "../src-tauri/empty-frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Forza drift telemetry + AI coach",
    "longDescription": "Self-hosted Forza Horizon 6/5 telemetry dashboard with a drift-tuning AI coach. Records sessions, builds a per-car dyno from your runs, and chats with a local or hosted LLM that knows drift tuning.",
    "resources": ["nuxt/**/*"],
    "externalBin": ["binaries/node-sidecar"]
  }
}
