# Dependencies + build outputs
node_modules/
.nuxt/
.output/
dist/

# Environment + secrets — never commit ANY env file with real values.
# .env.example is the only exception (template with empty values).
.env
.env.*
!.env.example

# Logs
*.log

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local backups (e.g. ~/.config files accidentally dropped here for inspection)
*.backup
*.broken-backup

# Tauri desktop build artifacts
src-tauri/target/
src-tauri/nuxt/                  # populated by desktop:copy-nuxt before bundle
src-tauri/binaries/              # populated by desktop:prep (per-platform Node binary, ~50MB)
src-tauri/gen/                   # auto-generated by tauri-build
src-tauri/icons/*.png            # generated by desktop:icons
src-tauri/icons/*.ico
src-tauri/icons/*.icns
src-tauri/icons/icon.png
src-tauri/icons/StoreLogo.png
